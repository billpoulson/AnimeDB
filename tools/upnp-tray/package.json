{
  "name": "animedb-upnp-tray",
  "version": "1.0.2",
  "description": "Windows system tray app for UPnP when running AnimeDB in Docker",
  "author": "AnimeDB",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "generate-icons": "node scripts/generate-status-icons.js",
    "build-test-update": "node scripts/build-test-update.js"
  },
  "build": {
    "appId": "com.animedb.upnp-tray",
    "productName": "AnimeDB UPnP",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "billpoulson",
      "repo": "AnimeDB",
      "vPrefixedTagName": false,
      "releaseType": "draft"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "nat-upnp-2": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "pngjs": "^7.0.0"
  }
}